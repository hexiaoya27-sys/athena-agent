# ===== 复制此文件为 .env 并填入真实值 =====
# cp .env.example .env

# ===== LLM API 配置 =====
LLM_API_KEY=your_api_key_here
LLM_BASE_URL=https://open.bigmodel.cn/api/paas/v4
LLM_MAIN_MODEL=glm-4-flash
LLM_ROUTER_MODEL=glm-4-flash

# ===== Embedding 模型 =====
EMBEDDING_MODEL=BAAI/bge-m3

# ===== PostgreSQL =====
POSTGRES_HOST=localhost
POSTGRES_PORT=5432
POSTGRES_USER=athena
POSTGRES_PASSWORD=change_me_in_production
POSTGRES_DB=athena

# ===== Redis =====
REDIS_HOST=localhost
REDIS_PORT=6379
REDIS_PASSWORD=change_me

# ===== Qdrant 向量数据库 =====
QDRANT_HOST=localhost
QDRANT_PORT=6333

# ===== 监控 =====
LANGSMITH_API_KEY=
LANGSMITH_PROJECT=athena-dev
SENTRY_DSN=

# ===== 应用配置 =====
APP_ENV=development
LOG_LEVEL=INFO
MAX_CONCURRENT_LLM_CALLS=10